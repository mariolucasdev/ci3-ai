# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true

# Matches multiple files with brace expansion notation
# Set default charset
[*]
charset = utf-8

# Tab indentation (no size specified)
indent_style = tab

# Pacote CI3 AI: 4 espaços, nunca tabs
[{application/third_party/ci3_ai/**,application/libraries/Ai.php,application/controllers/Ai_demo.php,application/config/ai.php,.php-cs-fixer.php}]
indent_style = space
indent_size = 4
